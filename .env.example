# TaskFlow standalone configuration.

PORT=3000
DATA_DIR="./data"
ADMIN_EMAILS="you@example.com"

# Leave DATABASE_URL empty to use SQLite at DATA_DIR/taskflow.sqlite.
# Set it to use Postgres instead.
# DATABASE_URL="postgres://taskflow:taskflow@localhost:5432/taskflow"

# Max upload size in bytes. Default is 25 MB.
MAX_UPLOAD_BYTES=26214400
