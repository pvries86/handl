# Handl standalone configuration.

PORT=3000
DATA_DIR="./data"
ADMIN_EMAILS="you@example.com"

# Leave DATABASE_URL empty to use SQLite at DATA_DIR/handl.sqlite.
# Set it to use Postgres instead.
# DATABASE_URL="postgres://taskflow:taskflow@localhost:5432/taskflow"

# Max upload size in bytes. Default is 25 MB.
MAX_UPLOAD_BYTES=26214400

# Optional Gmail IMAP mailbox ingestion. Requires Gmail IMAP and an app password.
MAIL_INGEST_ENABLED=false
MAIL_INGEST_HOST=imap.gmail.com
MAIL_INGEST_PORT=993
MAIL_INGEST_SECURE=true
MAIL_INGEST_USER=org@veridox.nl
MAIL_INGEST_PASSWORD=
MAIL_INGEST_FROM=paul@org.com
MAIL_INGEST_TO=org@veridox.nl
MAIL_INGEST_POLL_SECONDS=300
MAIL_INGEST_ARCHIVE_AFTER_PROCESSING=true
MAIL_INGEST_BOT_EMAIL=org@veridox.nl
MAIL_INGEST_BOT_NAME="Handl Mail Import"
